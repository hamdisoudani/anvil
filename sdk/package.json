{
  "name": "anvil-sdk",
  "version": "0.4.0",
  "private": true,
  "description": "Anvil agent engine + React SDK — TypeScript workspace",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --filter chat-app dev",
    "publish": "pnpm -r publish"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "^5.9.0"
  },
  "packageManager": "pnpm@9.15.0"
}
